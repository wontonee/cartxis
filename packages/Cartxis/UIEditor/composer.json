{
    "name": "cartxis/uieditor",
    "description": "Visual drag-and-drop UI Editor (Elementor-style) for Cartxis Commerce",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Cartxis Team",
            "email": "dev@cartxis.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "cartxis/cms": "*"
    },
    "autoload": {
        "psr-4": {
            "Cartxis\\UIEditor\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cartxis\\UIEditor\\Providers\\UIEditorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
